# ==========================================
# VLM x Robot Configuration
# ==========================================

# ----------------- OLLAMA (Default) -----------------
# To use Ollama, ensure it is running on the specified URL.
# No API key is needed, but "ollama" is used as a placeholder.
# VLM_API_KEY="ollama"
# VLM_BASE_URL="http://localhost:11434/v1"
# VLM_MODEL_NAME="llava:7b"

# ----------------- GEMINI (via OpenAI API) -----------------
# Get your API key from Google AI Studio.
# Base URL must include the OpenAI compatibility path.
# VLM_API_KEY="your-google-api-key-here"
# VLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# VLM_MODEL_NAME="gemini-robotics-er-1.5-preview"

# ==========================================
# ACTIVE CONFIGURATION
# ==========================================

VLM_API_KEY="your-google-api-key-here"
VLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
VLM_MODEL_NAME="gemini-robotics-er-1.5-preview"